#!/usr/bin/env zsh

dir=$0:A:h

config_dirs=(
  git
  hg
  nvim
  wezterm
)

declare -A links=(
  ssh/config ~/.ssh/config
  zsh/zshenv ~/.zshenv
)

create_dirs=(
  ~/.cache/zsh
  ~/.config
  ~/.local/share/{git,zsh}
  ~/.local/state/{less,ssh,zsh}
  ~/.ssh
)

cleanups=(
  ~/.bash*(N)
  ~/.cache/{nvim,zsh}
  ~/.lesshst
  ~/.local/share/{git,nvim,terminfo,zsh}
  ~/.local/state/zsh/theme  # keep history
  ~/.local/state/{less,nvim,ssh}
  ~/.profile
  ~/.vim*(N)
  ~/.zcomp*(N)
  ~/.zlogin
  ~/.zlogout
  ~/.zprofile
  ~/.zsh*(N)
)

if [[ -f $dir/local/setup.zsh ]]; then
  source $dir/local/setup.zsh
fi

if [[ $1 == --clean-only ]]; then
  rm -rfv $cleanups ~/.config/${^config_dirs}(N) ${(v)^links}(N)
  return
elif [[ $1 == --clean ]]; then
  rm -rfv $cleanups
fi

rm -rf ~/.config/${^config_dirs}(N) ${(v)^links}(N)
mkdir -p $create_dirs
ln -sfv $dir/${^config_dirs} ~/.config
for s d in ${(kv)links}; do
  ln -sfv $dir/$s $d
done

touch ~/.hushlogin

git_identity=~/.local/share/git/identity
mkdir -p $git_identity:h
git config -f $git_identity user.name $USER
git config -f $git_identity user.email '\<\>'

zsh -ilc 'nvim +qa 2> /dev/null'

mkdir -p ~/.local/share/terminfo
tic -xo $_/ $0:A:h/wezterm/wezterm.ti

if [[ $OSTYPE == darwin* ]]; then
  defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
fi
