[alias]
  l = log --graph --format='%Cred%h%Creset %s %Cgreen(%cr) %Cblue<%an>'

[diff]
  guitool = meld
  tool = vimdiff

[difftool "vimdiff"]
  cmd = vim -fdc 'cnoremap q qa|wincmd l|cd "$GIT_PREFIX"' "$LOCAL" "$REMOTE"

[init]
  defaultBranch = main

[merge]
  tool = meld

[mergetool]
  keepBackup = false

[pull]
  rebase = true

[user]
  name = tom
  email = \\<\\>
