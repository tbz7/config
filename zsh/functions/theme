#!/usr/bin/env zsh

zmodload zsh/mapfile
zmodload zsh/zutil

local CONFIG=~/.local/state/zsh/theme

local THEMES=(gotham gruvbox iceberg nord tokyonight)
local DEFAULT=iceberg

case $FONT_MODE in
  nerd|powerline) local -A sym=(о‚І о‚І о‚° о‚° вњ— вњ— в†і в†і вЂ¦ вЂ¦);;
  unicode13)      local -A sym=(о‚І рџ­® о‚° рџ­¬ вњ— вњ— в†і в†і вЂ¦ вЂ¦);;
  unicode)        local -A sym=(о‚І '' о‚° '' вњ— вњ— в†і в†і вЂ¦ вЂ¦);;
  *)              local -A sym=(о‚І '' о‚° '' вњ— x в†і '>' вЂ¦ ...);;
esac

local theme=
local -A palette=()

function .theme-main {
  local apps=(--term --zsh) flags=()
  zparseopts -D -E -K -a flags -term=apps -tmux=apps -zsh=apps -apply s

  local usage=false
  case $1 in
    apply)
      if (( $#@ > 2 )); then
        usage=true
      elif ! .theme-init $2; then
        return 1
      else
        if (( $flags[(I)-s] > 0 )); then
          mapfile[$CONFIG]=$theme
        fi

        if (( $apps[(I)--term] > 0 )); then
          .theme-apply-term
        fi
        if (( $apps[(I)--tmux] > 0 )); then
          .theme-apply-tmux
        fi
        if (( $apps[(I)--zsh] > 0 )); then
          .theme-apply-zsh
        fi
      fi;;
    list)
      if (( $#@ > 1 )); then
        usage=true
      else
        print -l $THEMES
      fi;;
    capture)
      if (( $#@ != 2 )); then
        usage=true
      else
        local captured=$(.theme-capture $2)
        if (( $flags[(I)--apply] > 0 )); then
          theme=$2
          palette=(${=captured:Q})
          .theme-apply-term
          .theme-apply-zsh
        else
          echo $captured
        fi
      fi
      ;;
    *)
      usage=true;;
  esac

  if $usage; then
    echo "Usage:"
    echo "  theme apply [-s] [--tmux] [--term] [--zsh] [THEME]"
    echo "  theme list"
    echo "  theme capture [--apply] THEME"
    return 1
  fi >&2
}

function .theme-init {
  theme=${1:-${THEME:-${mapfile[$CONFIG]:-$DEFAULT}}}
  if ! (( $THEMES[(I)$theme] )); then
    echo "Invalid theme: $theme" >&2
    return 1
  fi
  palette=(${(Pkv)${:-palette_$theme}})
}

function .theme-apply-term {
  local code name hex
  for code name (
      '4;0'   'black'
      '4;1'   'red'
      '4;2'   'green'
      '4;3'   'yellow'
      '4;4'   'blue'
      '4;5'   'magenta'
      '4;6'   'cyan'
      '4;7'   'white'
      '4;8'   'bright_black'
      '4;9'   'bright_red'
      '4;10'  'bright_green'
      '4;11'  'bright_yellow'
      '4;12'  'bright_blue'
      '4;13'  'bright_magenta'
      '4;14'  'bright_cyan'
      '4;15'  'bright_white'
       '10'   'fg'
       '11'   'bg'
       '17'   'visual_bg'
       '19'   'visual_fg') {
     hex=$palette[$name]
     echo -n "\e]$code;rgb:${hex:1:2}/${hex:3:2}/${hex:5:2}\a"
   }
 }

function .theme-apply-tmux {
  tmux set -g @status-z '%a %-I:%M %p' \;\
       set -g message-command-style "fg=$palette[bfg] bg=$palette[bbg]" \;\
       set -g message-style "fg=$palette[bfg] bg=$palette[bbg]" \;\
       set -g mode-style "fg=$palette[visual_fg] bg=$palette[visual_bg]" \;\
       set -g pane-active-border-style "fg=$palette[bfg] bg=$palette[bg]" \;\
       set -g pane-border-style "fg=$palette[bbg] bg=$palette[bg]" \;\
       set -g status-left '' \;\
       set -g status-right "#{T:@status-x} #{?@status-y,#[fg=$palette[bbg]]\
$sym[о‚І]#[fg=$palette[bfg] bg=$palette[bbg]] #{T:@status-y} ,}#{?@status-z,\
#[fg=$palette[abg]]$sym[о‚І]#[fg=$palette[afg] bg=$palette[abg]] #{T:@status-z} ,}" \;\
       set -g status-right-length 100 \;\
       set -g status-style "fg=$palette[cfg] bg=$palette[cbg]" \;\
       set -g window-status-current-format "#[fg=$palette[cbg] bg=$palette[bbg]\
]$sym[о‚°]#[fg=$palette[bfg]]  #W  #[fg=$palette[bbg] bg=$palette[cbg]]$sym[о‚°]" \;\
       set -g window-status-format ' #I #W   ' \;\
       set -g window-status-separator ''
}

function .theme-apply-zsh {
  if [[ $COLORTERM != truecolor ]]; then
    zmodload zsh/nearcolor
  fi

  export THEME=$theme
  export NVIM_COLORSCHEME=${(P)${:-colorscheme_$theme}:-$theme}

  local x
  for x in afg abg bfg bbg cfg cbg; do
    local $x="%(V.$palette[${x}i].%(2V.$palette[${x}2].$palette[$x]))"
  done

  local efg="%(V.$palette[cfgi].$palette[efg])"
  local ebg="%(V.$palette[cbgi].$palette[ebg])"

  PS1="%F{$afg}%K{$abg} %m %F{$abg}%K{$bbg}$sym[о‚°]"
  PS1+="%F{$bfg} %33<$sym[вЂ¦]<%~ %k%F{$bbg}$sym[о‚°]%f "
  RPS1="%(?..%F{$ebg}$sym[о‚І]%F{$efg}%K{$ebg} $sym[вњ—] %(3V.%F{$cbg}$sym[о‚І].))"
  RPS1+="%(3V.%(?.%F{$cbg}$sym[о‚І].)%F{$cfg}%K{$cbg} %3v .)%f%k"
  PS2="%8F$sym[в†і]  %f"
  RPS2="%8F %1^%f"
}

function .theme-capture {
  local scheme=$1
  local mode1=${2-normal}
  local mode2=${3-insert}
  local err=${4-ErrorMsg}

  () {
    NVIM_COLORSCHEME=$scheme nvim --headless -c "luafile $1" 2>&1
  } <(echo -E "
    function hi(name, key)
      if pcall(function() hl = vim.api.nvim_get_hl_by_name(name, true) end) then
        return hl and hl[key] and string.format('#%06x', hl[key]) or '#'
      end
      return '#'
    end

    function ansi(i)
      return vim.g['terminal_color_' .. i] or '#'
    end

    print(string.lower(
      '    fg              \'' .. hi('Normal', 'foreground') .. '\'\\n' ..
      '    bg              \'' .. hi('Normal', 'background') .. '\'\\n' ..
      '    black           \'' .. ansi(0) .. '\'\\n' ..
      '    red             \'' .. ansi(1) .. '\'\\n' ..
      '    green           \'' .. ansi(2) .. '\'\\n' ..
      '    yellow          \'' .. ansi(3) .. '\'\\n' ..
      '    blue            \'' .. ansi(4) .. '\'\\n' ..
      '    magenta         \'' .. ansi(5) .. '\'\\n' ..
      '    cyan            \'' .. ansi(6) .. '\'\\n' ..
      '    white           \'' .. ansi(7) .. '\'\\n' ..
      '    bright_black    \'' .. ansi(8) .. '\'\\n' ..
      '    bright_red      \'' .. ansi(9) .. '\'\\n' ..
      '    bright_green    \'' .. ansi(10) .. '\'\\n' ..
      '    bright_yellow   \'' .. ansi(11) .. '\'\\n' ..
      '    bright_blue     \'' .. ansi(12) .. '\'\\n' ..
      '    bright_magenta  \'' .. ansi(13) .. '\'\\n' ..
      '    bright_cyan     \'' .. ansi(14) .. '\'\\n' ..
      '    bright_white    \'' .. ansi(15) .. '\'\\n' ..
      '    visual_fg       \'' .. hi('Visual', 'foreground') .. '\'\\n' ..
      '    visual_bg       \'' .. hi('Visual', 'background') .. '\'\\n' ..
      '    afg             \'' .. hi('lualine_a_$mode1', 'foreground') .. '\'\\n' ..
      '    afg2            \'' .. hi('lualine_a_$mode2', 'foreground') .. '\'\\n' ..
      '    afgi            \'' .. hi('lualine_a_inactive', 'foreground') .. '\'\\n' ..
      '    abg             \'' .. hi('lualine_a_$mode1', 'background') .. '\'\\n' ..
      '    abg2            \'' .. hi('lualine_a_$mode2', 'background') .. '\'\\n' ..
      '    abgi            \'' .. hi('lualine_a_inactive', 'background') .. '\'\\n' ..
      '    bfg             \'' .. hi('lualine_b_$mode1', 'foreground') .. '\'\\n' ..
      '    bfg2            \'' .. hi('lualine_b_$mode2', 'foreground') .. '\'\\n' ..
      '    bfgi            \'' .. hi('lualine_b_inactive', 'foreground') .. '\'\\n' ..
      '    bbg             \'' .. hi('lualine_b_$mode1', 'background') .. '\'\\n' ..
      '    bbg2            \'' .. hi('lualine_b_$mode2', 'background') .. '\'\\n' ..
      '    bbgi            \'' .. hi('lualine_b_inactive', 'background') .. '\'\\n' ..
      '    cfg             \'' .. hi('lualine_c_$mode1', 'foreground') .. '\'\\n' ..
      '    cfg2            \'' .. hi('lualine_c_$mode2', 'foreground') .. '\'\\n' ..
      '    cfgi            \'' .. hi('lualine_c_inactive', 'foreground') .. '\'\\n' ..
      '    cbg             \'' .. hi('lualine_c_$mode1', 'background') .. '\'\\n' ..
      '    cbg2            \'' .. hi('lualine_c_$mode2', 'background') .. '\'\\n' ..
      '    cbgi            \'' .. hi('lualine_c_inactive', 'background') .. '\'\\n' ..
      '    efg             \'' .. hi('$err', 'foreground') .. '\'\\n' ..
      '    ebg             \'' .. hi('$err', 'background') .. '\'\\n'))

    vim.cmd('quit')")
}

